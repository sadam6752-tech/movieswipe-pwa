# ============================================================================
# Environment Variables for MovieSwipe PWA Docker
# ============================================================================
# Copy this file to .env and fill in your API keys
# ============================================================================

# TMDB API Key (for movie data)
# Get it from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# Poiskkino API Key (for Finnish movies)
# Get it from: https://www.poiskkino.fi/
POISKKINO_API_KEY=your_poiskkino_api_key_here

# Node environment
NODE_ENV=production
